<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <!-- 设置别名（可选，让Mapper中可以直接使用类名） -->
    <typeAliases>
        <package name="com.Mike12138210.pojo"/>
    </typeAliases>

    <!-- 配置数据库环境 -->
    <environments default="development">
        <environment id="development">
            <transactionManager type="JDBC"/>  <!-- 事务管理器 -->
            <dataSource type="POOLED">
                <property name="driver" value="com.mysql.cj.jdbc.Driver"/>  <!-- 驱动名称 -->
                <property name="url" value="jdbc:mysql://localhost:3306/dorm_repair?useSSL=false&amp;serverTimezone=UTC&amp;useUnicode=true&amp;characterEncoding=utf8"/>
                <property name="username" value="root"/>
                <property name="password" value="12345"/>
            </dataSource>
        </environment>
    </environments>

    <!-- 注册Mapper（后面创建了Mapper接口后再添加） -->
    <mappers>
        <!--加载sql映射文件-->
        <mapper resource="com/Mike12138210/dao/UserMapper.xml"/>
        <mapper resource="com/Mike12138210/dao/RepairOrderMapper.xml"/>
    </mappers>
</configuration>